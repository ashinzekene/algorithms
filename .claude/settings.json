{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite":["~/Library/Caches", "~/go/pkg/mod/cache/", "/tmp"]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "::1",
        "leetcode.com",
        "hackerrank.com",
        "www.hackerrank.com"
      ]
    },
    "enableWeakerNetworkIsolation": true
  }
}
